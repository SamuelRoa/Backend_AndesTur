# ==================== BASE DE DATOS ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=andestur
DB_USER=postgres
DB_PASSWORD=your_password

# ==================== SERVIDOR ====================
PORT=3000
NODE_ENV=development

# ==================== JWT ====================
JWT_SECRET=your-super-secret-key-change-this-in-production-12345
JWT_EXPIRATION=24h

# ==================== CORREO ELECTRÓNICO / SMTP ====================
# Para recuperación de contraseña por email
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_contraseña_o_password_de_aplicación

# Si usas Gmail, puedes dejar EMAIL_SERVICE como "gmail" y no definir SMTP_HOST
EMAIL_SERVICE=gmail

# Si usas otro proveedor SMTP define estos valores
# SMTP_HOST=smtp.tu-proveedor.com
# SMTP_PORT=465
# SMTP_SECURE=true

# ==================== APLICACIÓN ====================
APP_NAME=Andestur API
APP_VERSION=1.0.0
